{
  "name": "showcase-website-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10.13.1 <11"
  },
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "type-check": "next typegen && tsc --noEmit",
    "lint:check": "eslint . --ext .js,.jsx,.ts,.tsx --config eslint.config.mjs --cache --cache-location .eslintcache --max-warnings 0 && node scripts/starter-checks.js eslint-disable",
    "release:verify": "node scripts/starter-checks.js release-verify",
    "website:check": "pnpm type-check && pnpm lint:check && pnpm test && pnpm build",
    "website:build:cf": "pnpm exec opennextjs-cloudflare build --noMinify",
    "brand:check": "node scripts/starter-checks.js brand",
    "content:check": "node scripts/starter-checks.js content-slugs && node scripts/starter-checks.js translations",
    "component:governance:test": "pnpm exec vitest run tests/architecture/component-governance.test.ts tests/unit/scripts/component-governance-check.test.ts",
    "component:governance": "node scripts/starter-checks.js component-governance",
    "component:check": "pnpm component:governance:test && pnpm component:governance && pnpm exec storybook build"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.1",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/render": "^2.0.8",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "airtable": "0.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "next-intl": "^4.11.0",
    "next-themes": "0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-email": "6.0.5",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/compat": "2.0.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "16.2.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@opennextjs/cloudflare": "1.19.6",
    "@playwright/test": "^1.59.1",
    "@react-email/ui": "6.0.5",
    "@react-grab/mcp": "0.1.32",
    "@storybook/nextjs-vite": "^10.3.6",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-core": "^4.11.3",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.9.3",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-security-node": "1.1.4",
    "fast-check": "^4.7.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.1.0",
    "knip": "^6.7.0",
    "lefthook": "2.1.6",
    "playwright": "^1.59.1",
    "postcss": "^8.5.12",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react-grab": "^0.1.32",
    "react-scan": "^0.5.3",
    "react-server-dom-turbopack": "19.2.5",
    "react-server-dom-webpack": "19.2.5",
    "remark-frontmatter": "^5.0.0",
    "sharp": "^0.34.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "^4.1.5",
    "wrangler": "4.87.0"
  },
  "pnpm": {
    "overrides": {
      "@react-email/ui>next": "$next",
      "playwright@<1.55.1": ">=1.57.0",
      "vite@>=7.1.0 <7.3.0": ">=7.2.2",
      "tmp": "0.2.4",
      "js-yaml": "4.1.1",
      "mdast-util-to-hast": ">=13.2.1",
      "express": ">=4.22.0",
      "qs": ">=6.14.1",
      "lodash": "4.18.1",
      "@radix-ui/react-primitive": "2.1.4",
      "@radix-ui/react-slot": "1.2.4",
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "webpack@>=5.49.0 <5.104.1": ">=5.104.1",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.5",
      "next-intl@<4.11.0": ">=4.11.0",
      "postcss@<8.5.10": ">=8.5.10",
      "uuid": ">=14.0.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-import>eslint": "10",
        "eslint-plugin-jsx-a11y>eslint": "10",
        "eslint-plugin-react>eslint": "10"
      }
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "lefthook",
      "oxc-resolver",
      "sharp",
      "unrs-resolver"
    ]
  }
}
